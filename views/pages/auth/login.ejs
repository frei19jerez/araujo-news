<div class="container mt-5" style="max-width:500px;">

  <div class="card shadow border-0">

    <div class="card-header bg-danger text-white text-center">
      🚨 LOGIN ADMIN PUERTO ARAUJO NEWS 🚨
    </div>

    <div class="card-body p-4">

      <h2 class="mb-2 text-center text-danger">
        📰 Puerto Araujo Noticias
      </h2>

      <p class="text-center text-muted">
        Runtime independiente de DemoFlow
      </p>

      <hr>

      <form
        action="<%= baseUrl || '' %>/login"
        method="POST"
      >

        <div class="mb-3">

          <input
            type="email"
            name="email"
            class="form-control"
            placeholder="Correo administrador"
            required
          >

        </div>

        <div class="mb-3">

          <input
            type="password"
            name="password"
            class="form-control"
            placeholder="Contraseña administrador"
            required
          >

        </div>

        <button
          type="submit"
          class="btn btn-danger w-100"
        >
          🔐 Entrar a Puerto Araujo News
        </button>

      </form>

      <div class="alert alert-warning mt-3 mb-0 text-center">
        Si ves esta pantalla, estás dentro del login de Araujo News y NO en DemoFlow.
      </div>

      <div class="text-center mt-3">

        <a
          href="<%= baseUrl || '' %>/"
          class="text-decoration-none"
        >
          ← Volver al portal
        </a>

      </div>

    </div>

  </div>

</div>