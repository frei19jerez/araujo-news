<div class="container mt-4">

<h2 class="mb-4">📰 Publicaciones</h2>

<table class="table table-bordered bg-white shadow">

<tr>
<th>ID</th>
<th>Título</th>
<th>Acciones</th>
</tr>

<% noticias.forEach(function(n){ %>

<tr>
<td><%= n.id %></td>
<td><%= n.titulo %></td>
<td>

<a href="/admin/noticia/editar/<%= n.id %>" class="btn btn-warning btn-sm">
Editar
</a>

<form action="/admin/noticia/eliminar/<%= n.id %>" method="POST" style="display:inline;">
<button class="btn btn-danger btn-sm">
Eliminar
</button>
</form>

</td>
</tr>

<% }) %>

</table>

</div>