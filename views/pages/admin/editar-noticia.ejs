<div class="container mt-4 mb-5">

  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h1 class="fw-bold mb-0">✏️ Editar noticia</h1>

    <a href="<%= baseUrl %>/admin/publicaciones" class="btn btn-outline-dark">
      ⬅ Volver
    </a>
  </div>

  <div class="card shadow border-0">
    <div class="card-body p-4">

      <form action="<%= baseUrl %>/admin/noticia/actualizar/<%= noticia.id %>" method="POST">

        <div class="mb-3">
          <label class="form-label fw-semibold">Título</label>
          <input
            type="text"
            name="titulo"
            class="form-control"
            value="<%= noticia.titulo %>"
            required
          >
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold">Contenido</label>
          <textarea
            name="contenido"
            class="form-control"
            rows="8"
            required
          ><%= noticia.contenido %></textarea>
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold">Categoría</label>
          <select name="categoria" class="form-select">
            <option value="">Sin categoría</option>

            <% if (typeof categorias !== 'undefined' && categorias.length > 0) { %>
              <% categorias.forEach(function(c) { %>
                <option
                  value="<%= c.id %>"
                  <%= noticia.categoria == c.id ? 'selected' : '' %>
                >
                  <%= c.nombre %>
                </option>
              <% }); %>
            <% } %>
          </select>
        </div>

        <div class="d-flex gap-2 flex-wrap">
          <button type="submit" class="btn btn-success">
            ✅ Guardar cambios
          </button>

          <a href="<%= baseUrl %>/admin/publicaciones" class="btn btn-secondary">
            Cancelar
          </a>
        </div>

      </form>

    </div>
  </div>

</div>