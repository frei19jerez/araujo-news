<div class="container mt-4 mb-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold mb-0">✏️ Editar noticia</h1>
    <a href="/admin/publicaciones" class="btn btn-outline-dark">⬅ Volver</a>
  </div>

  <div class="card shadow border-0">
    <div class="card-body p-4">
      <form action="/admin/noticia/actualizar/<%= noticia.id %>" method="POST">

        <div class="mb-3">
          <label class="form-label fw-semibold">Título</label>
          <input type="text" name="titulo" class="form-control" value="<%= noticia.titulo %>" required>
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold">Contenido</label>
          <textarea name="contenido" class="form-control" rows="8" required><%= noticia.contenido %></textarea>
        </div>

        <button type="submit" class="btn btn-primary w-100">Guardar cambios</button>
      </form>
    </div>
  </div>
</div>