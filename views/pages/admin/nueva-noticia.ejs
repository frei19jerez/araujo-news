<div class="container mt-4 mb-5">

  <!-- ENCABEZADO -->
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h1 class="fw-bold mb-0">📝 Nueva noticia</h1>

    <div class="d-flex gap-2">
      <a href="<%= baseUrl %>/admin/publicaciones" class="btn btn-outline-dark">
        📰 Publicaciones
      </a>

      <a href="<%= baseUrl %>/admin" class="btn btn-secondary">
        ⬅ Panel
      </a>
    </div>
  </div>

  <!-- FORMULARIO -->
  <div class="card shadow border-0">
    <div class="card-body p-4">

      <form
        action="<%= baseUrl %>/admin/noticia/crear"
        method="POST"
        enctype="multipart/form-data">

        <div class="mb-3">
          <label class="form-label fw-semibold">
            Título
          </label>

          <input
            type="text"
            name="titulo"
            class="form-control"
            placeholder="Escribe el título de la noticia"
            required>
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold">
            Contenido
          </label>

          <textarea
            name="contenido"
            class="form-control"
            rows="8"
            placeholder="Escribe aquí la noticia..."
            required></textarea>
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold">
            Categoría de publicación
          </label>

          <select
            name="categoria"
            class="form-select shadow-sm"
            required>

            <option value="">
              📂 Seleccione una categoría
            </option>

            <% if (
              typeof categorias !== 'undefined' &&
              Array.isArray(categorias) &&
              categorias.length > 0
            ) { %>

              <% categorias.forEach(function (categoria) { %>

                <option value="<%= categoria.id %>">
                  <%= categoria.nombre %>
                </option>

              <% }); %>

            <% } else { %>

              <option value="" disabled>
                No hay categorías registradas
              </option>

            <% } %>

          </select>

          <div class="form-text">
            Esta categoría define en qué sección del portal aparecerá la noticia.
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold">
            Imagen de portada
          </label>

          <input
            type="file"
            name="imagen"
            class="form-control"
            accept="image/jpeg,image/png,image/webp">

          <div class="form-text">
            Formatos recomendados: JPG, PNG o WEBP.
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold">
            Video
          </label>

          <input
            type="file"
            name="video"
            class="form-control"
            accept="video/*">

          <div class="form-text">
            Para videos largos se recomienda usar YouTube.
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold">
            Enlace de YouTube
          </label>

          <input
            type="url"
            name="youtubeUrl"
            class="form-control"
            placeholder="https://www.youtube.com/watch?v=...">

          <div class="form-text">
            Pega aquí el enlace si el video está alojado en YouTube.
          </div>
        </div>

        <div class="form-check mb-4">
          <input
            class="form-check-input"
            type="checkbox"
            name="destacada"
            value="1"
            id="destacada">

          <label
            class="form-check-label fw-semibold"
            for="destacada">

            ⭐ Marcar como noticia destacada

          </label>
        </div>

        <div class="row g-2">

          <div class="col-md-8">
            <button
              type="submit"
              class="btn btn-success w-100">

              ✅ Publicar noticia

            </button>
          </div>

          <div class="col-md-4">
            <a
              href="<%= baseUrl %>/admin/publicaciones"
              class="btn btn-outline-secondary w-100">

              Cancelar

            </a>
          </div>

        </div>

      </form>

    </div>
  </div>

</div>