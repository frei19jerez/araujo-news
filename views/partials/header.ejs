<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm sticky-top">
  <div class="container">

    <%
      /*
       * Prefijo del runtime.
       *
       * DemoFlow envía:
       * X-Runtime-Prefix: /runtime/araujo-news
       *
       * Si la aplicación se abre directamente, queda vacío.
       */

      var baseUrl = '';

      if (
        typeof req !== 'undefined' &&
        req.headers &&
        req.headers['x-runtime-prefix']
      ) {
        baseUrl = req.headers['x-runtime-prefix'];
      } else if (
        typeof req !== 'undefined' &&
        req.originalUrl &&
        req.originalUrl.indexOf('/runtime/araujo-news') === 0
      ) {
        baseUrl = '/runtime/araujo-news';
      }

      /*
       * Evitar una barra final duplicada.
       */
      if (
        baseUrl &&
        baseUrl.endsWith('/')
      ) {
        baseUrl = baseUrl.slice(0, -1);
      }

      /*
       * Saber si el administrador de Araujo News
       * tiene una sesión activa.
       */
      var adminAraujoAutenticado =
        typeof req !== 'undefined' &&
        req.session &&
        req.session.araujoUserId;
    %>

    <a
      class="navbar-brand fw-bold d-flex align-items-center gap-2"
      href="<%= baseUrl %>/"
    >
      <span>📰</span>
      <span>Puerto Araujo Noticias</span>
    </a>

    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#menuPrincipal"
      aria-controls="menuPrincipal"
      aria-expanded="false"
      aria-label="Abrir menú"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <div
      class="collapse navbar-collapse"
      id="menuPrincipal"
    >
      <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">

        <li class="nav-item">
          <a
            class="nav-link px-3"
            href="<%= baseUrl %>/"
          >
            🏠 Inicio
          </a>
        </li>

        <% if (adminAraujoAutenticado) { %>

          <li class="nav-item">
            <a
              class="nav-link text-warning fw-semibold px-3"
              href="<%= baseUrl %>/admin"
            >
              ⚙️ Panel
            </a>
          </li>

          <li class="nav-item">
            <a
              class="btn btn-danger btn-sm px-3"
              href="<%= baseUrl %>/logout"
            >
              Salir
            </a>
          </li>

        <% } else { %>

          <li class="nav-item">
            <a
              class="btn btn-outline-light btn-sm px-3"
              href="<%= baseUrl %>/login"
            >
              🔐 Admin
            </a>
          </li>

        <% } %>

      </ul>
    </div>

  </div>
</nav>